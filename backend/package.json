{
  "name": "projectlvqi-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "lint": "echo \"lint not configured\"",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:generate:desktop": "prisma generate --schema prisma/schema.desktop.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "ts-node prisma/seed.ts",
    "test:api": "jest --config test/jest-e2e.json --testPathPattern=api",
    "test:api:audit": "jest --config test/jest-e2e.json test/api/audit.spec.ts",
    "test:api:permissions": "jest --config test/jest-e2e.json test/api/permissions.spec.ts",
    "test:api:users": "jest --config test/jest-e2e.json test/api/users.spec.ts",
    "test:e2e": "npx playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^3.0.4",
    "@prisma/client": "^6.19.2",
    "@types/bcrypt": "^5.0.2",
    "@types/pdf-parse": "^1.1.5",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "diff": "^7.0.0",
    "ioredis": "^5.10.1",
    "mammoth": "^1.11.0",
    "nodemailer": "^6.9.16",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@playwright/test": "^1.58.2",
    "@types/diff": "^5.2.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.17.19",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
