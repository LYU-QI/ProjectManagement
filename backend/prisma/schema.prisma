generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  project_manager
  pm
  member
  viewer
}

enum OrgRole {
  owner
  admin
  member
  viewer
}

enum AuditOutcome {
  success
  failed
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum ProjectRole {
  director
  manager
  member
  viewer
}

enum RequirementStatus {
  draft
  in_review
  approved
  planned
  done
}

enum RequirementPriority {
  low
  medium
  high
}

enum ReviewDecision {
  approved
  rejected
}

enum CostType {
  labor
  outsource
  cloud
}

enum TaskStatus {
  todo
  in_progress
  blocked
  done
}

enum NotificationLevel {
  info
  warning
  error
}

enum RiskRuleType {
  deadline_progress
  blocked
  overdue
}

enum DependencyType {
  FS
  SS
  FF
}

enum WorkItemType {
  todo
  issue
}

enum WorkItemPriority {
  low
  medium
  high
}

enum WorkItemStatus {
  todo
  in_progress
  in_review
  done
  closed
}

enum WorkItemHistoryField {
  status
  assignee
  dueDate
  description
  parentId
}

enum MilestoneBoardStatus {
  upcoming
  in_progress
  completed
}

enum MilestoneBoardRisk {
  low
  medium
  high
}

enum TestCaseStatus {
  draft
  active
  deprecated
}

enum TestCasePriority {
  low
  medium
  high
  critical
}

enum TestPlanStatus {
  draft
  active
  completed
  archived
}

enum BugStatus {
  open
  in_progress
  resolved
  closed
  rejected
}

enum BugSeverity {
  trivial
  minor
  major
  critical
  blocker
}

enum BugPriority {
  low
  medium
  high
  urgent
}

model Organization {
  id         String      @id @default(cuid())
  slug       String      @unique
  name       String
  plan       Plan        @default(FREE)
  maxMembers Int         @default(25)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  members    OrgMember[]
  projects   Project[]
  configs    Config[]
  wikiPages  WikiPage[]
  departments Department[]
  automationRules AutomationRule[]
  orgApiKeys OrgApiKey[]
  webhooks OrgWebhook[]
  capabilityTemplates CapabilityTemplate[]

  allowedIps String?

  @@index([slug])
}

model OrgMember {
  id             String       @id @default(cuid())
  userId         Int
  organizationId String
  orgRole        OrgRole      @default(member)
  departmentId   String?
  totpVerified  Boolean     @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  department     Department?  @relation(fields: [departmentId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  feishuDeptId  String?
  name           String
  parentId       String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  parent         Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children       Department[] @relation("DeptHierarchy")
  members       OrgMember[]

  @@index([organizationId])
  @@index([feishuDeptId])
}

model Config {
  id             String        @id @default(cuid())
  organizationId String?
  key            String
  value          String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId])
}

model CapabilityTemplate {
  id                 String        @id @default(cuid())
  organizationId     String?
  projectId          Int?
  scene              String
  name               String
  description        String?
  systemPrompt       String?
  userPromptTemplate String?
  enabled            Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  organization       Organization? @relation(fields: [organizationId], references: [id])
  project            Project?      @relation(fields: [projectId], references: [id])

  @@index([organizationId, scene, enabled])
  @@index([projectId, scene, enabled])
  @@unique([organizationId, projectId, scene, name])
}

model User {
  id            Int                 @id @default(autoincrement())
  name          String
  username      String?             @unique
  password      String?
  role          UserRole
  feishuOpenId  String?
  feishuUnionId String?
  defaultOrgId  String?
  totpSecret    String?
  totpEnabled   Boolean @default(false)
  projects      Project[]           @relation("ProjectOwner")
  memberships   ProjectMembership[]
  orgMemberships OrgMember[]
  worklogs      Worklog[]
  createdWorkItems  WorkItem[]        @relation("WorkItemCreator")
  assignedWorkItems WorkItem[]        @relation("WorkItemAssignee")
  workItemHistories WorkItemHistory[] @relation("WorkItemHistoryChangedBy")
}

model Project {
  id             Int                 @id @default(autoincrement())
  organizationId String
  name           String
  alias          String?             @unique
  ownerId        Int
  budget         Float
  startDate      String?
  endDate        String?
  feishuChatIds  String?
  feishuAppToken String?
  feishuTableId  String?
  owner          User                @relation("ProjectOwner", fields: [ownerId], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id])
  memberships    ProjectMembership[]
  requirements   Requirement[]
  costs          CostEntry[]
  milestones     Milestone[]
  tasks          Task[]
  worklogs       Worklog[]
  notifications  Notification[]
  prdDocuments   PrdDocument[]
  pmJobConfigs   PmAssistantProjectJobConfig[]
  pmPrompts      PmAssistantProjectPrompt[]
  pmSchedules    PmAssistantProjectSchedule[]
  pmLogs         PmAssistantLog[]
  workItems      WorkItem[]
  milestoneBoardItems MilestoneBoardItem[]
  sprints           Sprint[]
  testCases      TestCase[]
  testPlans      TestPlan[]
  bugs           Bug[]
  wikiPages      WikiPage[]
  capabilityTemplates CapabilityTemplate[]

  @@index([organizationId])
}

model WorkItem {
  id          Int              @id @default(autoincrement())
  projectId   Int?
  title       String
  description String?
  type        WorkItemType
  priority    WorkItemPriority @default(medium)
  status      WorkItemStatus   @default(todo)
  assigneeId  Int?
  assigneeName String?
  creatorId   Int
  dueDate     String?
  parentId    Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  project     Project?         @relation(fields: [projectId], references: [id])
  creator     User             @relation("WorkItemCreator", fields: [creatorId], references: [id])
  assignee    User?            @relation("WorkItemAssignee", fields: [assigneeId], references: [id])
  histories   WorkItemHistory[]
  parent      WorkItem?        @relation("WorkItemSubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    WorkItem[]      @relation("WorkItemSubTasks")

  @@index([projectId, status, priority])
  @@index([creatorId, status])
  @@index([assigneeId, status])
  @@index([assigneeName, status])
  @@index([dueDate])
  @@index([parentId])
}

model WorkItemHistory {
  id          Int                  @id @default(autoincrement())
  workItemId  Int
  field       WorkItemHistoryField
  beforeValue String?
  afterValue  String?
  changedById Int
  createdAt   DateTime             @default(now())
  workItem    WorkItem             @relation(fields: [workItemId], references: [id])
  changedBy   User                 @relation("WorkItemHistoryChangedBy", fields: [changedById], references: [id])

  @@index([workItemId, id])
  @@index([changedById, createdAt])
}

model ProjectMembership {
  id             Int         @id @default(autoincrement())
  userId         Int
  projectId      Int
  organizationId String?
  role           ProjectRole @default(member)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id])
  project        Project     @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([organizationId])
}

model Requirement {
  id          Int                 @id @default(autoincrement())
  projectId   Int
  projectSeq  Int
  title       String
  description String
  priority    RequirementPriority
  status      RequirementStatus   @default(draft)
  version     String?
  changeCount Int                 @default(0)
  createdAt   DateTime            @default(now())
  project     Project             @relation(fields: [projectId], references: [id])
  reviews     RequirementReview[]
  changes     RequirementChange[]

  @@unique([projectId, projectSeq])
}

model RequirementReview {
  id            Int            @id @default(autoincrement())
  requirementId Int
  reviewer      String
  decision      ReviewDecision
  comment       String?
  createdAt     DateTime       @default(now())
  requirement   Requirement    @relation(fields: [requirementId], references: [id])
}

model RequirementChange {
  id            Int         @id @default(autoincrement())
  requirementId Int
  changedBy     String?
  reason        String?
  before        Json?
  after         Json?
  version       String?
  createdAt     DateTime    @default(now())
  requirement   Requirement @relation(fields: [requirementId], references: [id])
}

model PrdDocument {
  id        Int          @id @default(autoincrement())
  projectId Int
  title     String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  project   Project      @relation(fields: [projectId], references: [id])
  versions  PrdVersion[]

  @@index([projectId])
}

model PrdVersion {
  id           Int         @id @default(autoincrement())
  documentId   Int
  versionLabel String?
  fileName     String
  mimeType     String?
  fileSize     Int?
  storagePath  String
  contentText  String      @db.Text
  contentHash  String
  createdAt    DateTime    @default(now())
  document     PrdDocument @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([contentHash])
}

model CostEntry {
  id         Int      @id @default(autoincrement())
  projectId  Int
  type       CostType
  amount     Float
  occurredOn String
  note       String?
  project    Project  @relation(fields: [projectId], references: [id])
}

model Milestone {
  id          Int     @id @default(autoincrement())
  projectId   Int
  name        String
  plannedDate String
  actualDate  String?
  project     Project @relation(fields: [projectId], references: [id])
}

model MilestoneBoardItem {
  id          Int                 @id @default(autoincrement())
  projectId   Int
  title       String
  owner       String
  due         String
  status      MilestoneBoardStatus @default(upcoming)
  risk        MilestoneBoardRisk   @default(low)
  progress    Int                 @default(0)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliverables MilestoneBoardDeliverable[]

  @@index([projectId, status, due])
  @@index([projectId, sortOrder])
}

model MilestoneBoardDeliverable {
  id          Int               @id @default(autoincrement())
  milestoneId Int
  content     String
  done        Boolean           @default(false)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  milestone   MilestoneBoardItem @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId, sortOrder])
}

model Task {
  id           Int        @id @default(autoincrement())
  projectId    Int
  title        String
  assignee     String
  status       TaskStatus
  plannedStart String
  plannedEnd   String
  project      Project    @relation(fields: [projectId], references: [id])
}

model FeishuDependency {
  id                Int            @id @default(autoincrement())
  organizationId    String?
  projectName       String
  taskRecordId      String
  taskId            String?
  dependsOnRecordId String
  dependsOnTaskId   String?
  type              DependencyType @default(FS)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([taskRecordId, dependsOnRecordId, type])
  @@index([organizationId])
}

model Worklog {
  id           Int      @id @default(autoincrement())
  projectId    Int
  userId       Int?
  assigneeName String?
  taskTitle    String?
  weekStart    String?
  weekEnd      String?
  totalDays    Float?
  hours        Float
  hourlyRate   Float
  workedOn     String
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])
}

model PmAssistantLog {
  id             Int      @id @default(autoincrement())
  organizationId String?
  projectId     Int?
  jobId         String
  triggeredBy   String
  status        String
  summary       String
  rawSummary    String?
  aiSummary     String?
  error         String?
  createdAt     DateTime @default(now())
  project       Project? @relation(fields: [projectId], references: [id])

  @@index([organizationId])
  @@index([projectId])
}

model PmAssistantJobConfig {
  id        Int      @id @default(autoincrement())
  jobId     String   @unique
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model PmAssistantProjectJobConfig {
  id        Int      @id @default(autoincrement())
  projectId Int
  jobId     String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, jobId])
  @@index([projectId])
}

model PmAssistantProjectPrompt {
  id        Int      @id @default(autoincrement())
  projectId Int
  jobId     String
  prompt    String
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, jobId])
  @@index([projectId])
}

model PmAssistantProjectSchedule {
  id         Int      @id @default(autoincrement())
  projectId  Int
  scheduleId String
  cron       String
  timezone   String
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, scheduleId])
  @@index([projectId])
}

model Notification {
  id        Int               @id @default(autoincrement())
  projectId Int?
  level     NotificationLevel @default(info)
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime          @default(now())
  project   Project?          @relation(fields: [projectId], references: [id])
}

model RiskRule {
  id                Int           @id @default(autoincrement())
  organizationId    String?
  key               String
  type              RiskRuleType  @default(deadline_progress)
  name              String
  enabled           Boolean       @default(true)
  thresholdDays     Int
  progressThreshold Int
  blockedValue      String?       @default("是")
  includeMilestones Boolean       @default(false)
  autoNotify        Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  alerts            RiskAlert[]
  logs              RiskRuleLog[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model RiskRuleLog {
  id        Int      @id @default(autoincrement())
  ruleId    Int
  action    String
  note      String?
  createdAt DateTime @default(now())
  rule      RiskRule @relation(fields: [ruleId], references: [id])
}

model RiskAlert {
  id         Int      @id @default(autoincrement())
  ruleId     Int
  recordId   String
  taskId     String?
  taskName   String?
  project    String?
  endDate    String?
  progress   Float?
  daysLeft   Int?
  notifiedAt DateTime @default(now())
  rule       RiskRule @relation(fields: [ruleId], references: [id])

  @@unique([ruleId, recordId])
}

model AuditLog {
  id             Int      @id @default(autoincrement())
  userId         Int?
  userName       String?
  userRole       String?
  method         String
  path           String
  source         String?
  projectId      Int?
  organizationId String?
  requestBody    Json?
  beforeSnapshot Json?
  afterSnapshot  Json?
  outcome        AuditOutcome @default(success)
  statusCode     Int?
  errorMessage   String?
  resourceType   String?
  resourceId     String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([outcome])
  @@index([source])
  @@index([resourceType])
}

model TestCase {
  id             Int              @id @default(autoincrement())
  projectId      Int
  organizationId String?
  title          String
  description    String?          @db.Text
  preconditions  String?          @db.Text
  steps          Json?
  expectedResult String?          @db.Text
  priority       TestCasePriority @default(medium)
  status         TestCaseStatus   @default(draft)
  tags           String?
  creatorId      Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  project        Project          @relation(fields: [projectId], references: [id])
  testPlanItems  TestPlanItem[]
  bugs           Bug[]

  @@index([projectId, status])
  @@index([organizationId])
}

model TestPlan {
  id             Int            @id @default(autoincrement())
  projectId      Int
  organizationId String?
  title          String
  description    String?        @db.Text
  status         TestPlanStatus @default(draft)
  startDate      String?
  endDate        String?
  creatorId      Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  project        Project        @relation(fields: [projectId], references: [id])
  items          TestPlanItem[]

  @@index([projectId, status])
  @@index([organizationId])
}

model TestPlanItem {
  id         Int       @id @default(autoincrement())
  planId     Int
  testCaseId Int
  result     String?
  notes      String?
  executedAt DateTime?
  executorId Int?
  createdAt  DateTime  @default(now())
  plan       TestPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  testCase   TestCase  @relation(fields: [testCaseId], references: [id])

  @@unique([planId, testCaseId])
  @@index([planId])
}

model Bug {
  id             Int         @id @default(autoincrement())
  projectId      Int
  organizationId String?
  testCaseId     Int?
  title          String
  description    String?     @db.Text
  steps          String?     @db.Text
  severity       BugSeverity @default(major)
  priority       BugPriority @default(medium)
  status         BugStatus   @default(open)
  assigneeId     Int?
  assigneeName   String?
  reporterId     Int?
  reporterName   String?
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project     @relation(fields: [projectId], references: [id])
  testCase       TestCase?   @relation(fields: [testCaseId], references: [id])

  @@index([projectId, status, severity])
  @@index([organizationId])
  @@index([assigneeId])
}

enum SprintStatus {
  planning
  active
  completed
  cancelled
}

model Sprint {
  id             Int         @id @default(autoincrement())
  projectId      Int
  organizationId String?
  name           String
  goal           String?     @db.Text
  status         SprintStatus @default(planning)
  startDate      String?
  endDate        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project     @relation(fields: [projectId], references: [id])

  @@index([projectId, status])
}

enum WikiPageType {
  document
  folder
}

model WikiPage {
  id             Int         @id @default(autoincrement())
  projectId      Int
  organizationId String?
  parentId       Int?
  title          String
  content        String      @db.Text
  type           WikiPageType @default(document)
  slug           String
  sortOrder      Int         @default(0)
  creatorId      Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  project        Project     @relation(fields: [projectId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  parent         WikiPage?   @relation("WikiPageChildren", fields: [parentId], references: [id])
  children       WikiPage[]  @relation("WikiPageChildren")

  @@index([projectId])
  @@index([organizationId])
  @@index([parentId])
  @@index([projectId, sortOrder])
}

model FeishuUser {
  id             Int      @id @default(autoincrement())
  organizationId String?
  name           String
  openId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum AutomationTrigger {
  requirement_created
  requirement_status_changed
  workitem_created
  workitem_status_changed
  bug_created
  bug_severity_critical
  cost_over_budget
  milestone_due_soon
}

enum AutomationAction {
  send_notification
  update_status
  assign_to_user
  create_workitem
  send_webhook
}

model AutomationRule {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  description    String?
  enabled        Boolean           @default(true)
  trigger        AutomationTrigger
  conditions     Json
  actions        Json
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id])
  logs           AutomationLog[]

  @@index([organizationId])
  @@index([trigger])
}

model AutomationLog {
  id           String         @id @default(cuid())
  ruleId       String
  executionAt  DateTime      @default(now())
  trigger      String
  payload      Json
  actionsRun   Json
  success      Boolean
  error        String?
  rule         AutomationRule @relation(fields: [ruleId], references: [id])
}

model OrgApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  keyPrefix      String       @default(cuid())
  keyHash        String
  permissions    String[]
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model OrgWebhook {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  url             String
  secret          String?
  events          String[]
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lastTriggeredAt DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id])
  deliveries      OrgWebhookDelivery[]

  @@index([organizationId])
}

model OrgWebhookDelivery {
  id          String     @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  success     Boolean
  response    String?
  error       String?
  attemptedAt DateTime   @default(now())
  webhook     OrgWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
}
